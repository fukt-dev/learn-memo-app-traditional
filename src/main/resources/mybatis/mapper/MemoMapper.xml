<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<!--
    MemoMapper の SQL 本体（2waySQL）。

    MemoMapper.java の各メソッドに、id をメソッド名と一致させて SQL を対応づける。
    このファイルは「クエリ固有の意図」だけを説明する。2waySQL とは何か・#{} と ${} の違い・
    resultType と resultMap・動的 SQL タグ（if / where / choose / foreach / set）などの汎用解説は
    docs/MyBatis2waySQL解説.md（docs/ 直下）にまとめてある。

    補足: 型パラメータは、XML コメント内では山括弧が使えないため List[Memo] のように角括弧で表記する
    （実際の Java コードでは半角の山括弧を使う）。
-->

<!--
    namespace は MemoMapper インターフェースの完全修飾名。これが一致することで MyBatis が
    インターフェースと XML を結びつける。
-->
<mapper namespace="com.example.memoapp.mapper.MemoMapper">

    <!--
        findAll: 全件取得。
        一覧は新しいメモを上に見せたいので created_at の降順でソートする。
        カラムは SELECT * ではなく明示列挙し、取得列を意図的に固定している。
    -->
    <select id="findAll" resultType="Memo">
        SELECT id, title, content, created_at, updated_at FROM memos ORDER BY created_at DESC
    </select>

    <!--
        findById: ID 指定で 1 件取得。
        id は PRIMARY KEY なので結果は必ず 0 件か 1 件。LIMIT 1 は不要で、MyBatis が
        0/1 件を Optional[Memo] に変換する。
    -->
    <select id="findById" resultType="Memo">
        SELECT id, title, content, created_at, updated_at FROM memos WHERE id = #{id}
    </select>

    <!--
        insert: 新規登録。
        useGeneratedKeys="true" と keyProperty="id" で、DB が採番した id を引数の Memo.id へ戻す
        （呼び出し元は insert 後に memo.getId() で採番結果を受け取れる）。
        created_at / updated_at は指定しない。DB の DEFAULT CURRENT_TIMESTAMP が入る。
    -->
    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO memos (title, content) VALUES (#{title}, #{content})
    </insert>

    <!--
        update: 更新。戻り値は影響行数（1=成功、0=対象 id なし）。
        updated_at はここで書かない。V1__Create_memos_table.sql のトリガーが UPDATE 時に
        現在時刻へ自動更新する。
    -->
    <update id="update">
        UPDATE memos SET title = #{title}, content = #{content} WHERE id = #{id}
    </update>

    <!--
        deleteById: ID 指定で削除（物理削除）。戻り値は影響行数（1=成功、0=対象 id なし）。
    -->
    <delete id="deleteById">
        DELETE FROM memos WHERE id = #{id}
    </delete>

    <!--
        searchByKeyword: タイトルまたは本文の部分一致検索。並び順は findAll と同じ新しい順。

        【落とし穴: LIKE のワイルドカード文字をエスケープしていない】
        % と _ は LIKE では「任意の文字列」「任意の 1 文字」を表す特殊文字。ユーザーが「100%」と
        入力すると条件は LIKE '%100%%' となり「100」を含む全メモがヒットする（「100%」ちょうどの
        絞り込みにならない）。厳密にするには Service 層で % _ \ を \% \_ \\ に置換し、
        LIKE ... ESCAPE '\' を使う。このアプリは「余計にヒットするだけで実害が小さい」ため、
        学習用にシンプルさを優先してあえてエスケープしていない。

        【性能の注意】LIKE '%...%' は B-tree インデックスが効かず全行走査になる。
        V1 の GIN インデックスも全文検索演算子（@@）専用で、この LIKE には使われない。
        速くする方法（pg_trgm など）は V1__Create_memos_table.sql のコメントを参照。
    -->
    <select id="searchByKeyword" resultType="Memo">
        SELECT id, title, content, created_at, updated_at
        FROM memos
        WHERE title LIKE CONCAT('%', #{keyword}, '%') OR content LIKE CONCAT('%', #{keyword}, '%')
        ORDER BY created_at DESC
    </select>

    <!--
        findAllWithPaging: ページング付き全件取得（実装演習用・未使用）。
        limit=取得件数、offset=スキップ件数。offset が大きいと遅くなる（キーセットページ
        ネーション等で改善できる）。演習手順は MemoService のコメント参照。
    -->
    <select id="findAllWithPaging" resultType="Memo">
        SELECT id, title, content, created_at, updated_at
        FROM memos
        ORDER BY created_at DESC
        LIMIT #{limit} OFFSET #{offset}
    </select>

    <!--
        count: 総件数（実装演習用・未使用）。総ページ数の計算に使う。
    -->
    <select id="count" resultType="long">
        SELECT COUNT(*) FROM memos
    </select>

</mapper>
