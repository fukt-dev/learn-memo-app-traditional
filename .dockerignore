# ============================================
# .dockerignore
# ============================================
# このファイルは、Dockerイメージにコピーしたくないファイルを指定します
# .gitignoreと似た仕組みです
#
# 【目的】
# 1. ビルド時間の短縮（不要なファイルをコピーしない）
# 2. イメージサイズの削減
# 3. セキュリティ向上（機密情報を含むファイルを除外）
#
# 【記法】
# - 各行に1つのパターンを記述
# - # で始まる行はコメント
# - * はワイルドカード（任意の文字列）
# - ! で始まる行は除外の例外（このファイルは含める）

# --------------------------------------------
# Git関連
# --------------------------------------------
# Gitの管理ファイルは不要
.git
.gitignore
.gitattributes

# --------------------------------------------
# ビルド成果物
# --------------------------------------------
# Mavenのビルド成果物
# Dockerfile内で mvn package を実行するため、
# ローカルのtarget/ディレクトリは不要
target/
!target/*.jar

# --------------------------------------------
# IDE関連
# --------------------------------------------
# IntelliJ IDEA
.idea/
*.iml
*.iws
*.ipr

# Eclipse
.classpath
.project
.settings/
bin/

# Visual Studio Code
.vscode/
*.code-workspace

# NetBeans
nbproject/
nbbuild/
dist/
nbdist/

# --------------------------------------------
# OS生成ファイル
# --------------------------------------------
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~
.directory

# --------------------------------------------
# ログファイル
# --------------------------------------------
# アプリケーションログ
*.log
logs/

# --------------------------------------------
# 一時ファイル
# --------------------------------------------
# 一時ファイル・キャッシュ
*.tmp
*.temp
*.swp
*.swo
*~
.cache/

# --------------------------------------------
# ドキュメント
# --------------------------------------------
# ドキュメントはイメージに含める必要がない
# （実行に不要なため）
docs/
*.md
!README.md

# --------------------------------------------
# Docker関連
# --------------------------------------------
# Dockerファイルそのものは不要
Dockerfile
.dockerignore
docker-compose.yml
.docker/

# --------------------------------------------
# テスト関連
# --------------------------------------------
# テストコードはビルド時に使用されますが、
# 最終的な実行イメージには不要
# ただし、Dockerfile内でコピーする必要があるため、
# ここでは除外しません（必要に応じてコメント解除）
# src/test/

# --------------------------------------------
# 環境設定ファイル
# --------------------------------------------
# ローカル環境固有の設定ファイル
.env
.env.local
.env.*.local

# Spring Boot DevTools用の設定
# （本番環境では不要）
.spring-boot-devtools.properties

# --------------------------------------------
# 依存関係管理
# --------------------------------------------
# Maven wrapper（既にDockerイメージに含まれているため不要）
# 注: Mavenラッパーを使う場合はコメントアウト
.mvn/
mvnw
mvnw.cmd

# Node.js（もしフロントエンドで使う場合）
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# --------------------------------------------
# データベース
# --------------------------------------------
# ローカルのデータベースファイル（SQLiteなど）
*.db
*.sqlite
*.sqlite3

# --------------------------------------------
# セキュリティ関連
# --------------------------------------------
# 秘密鍵・証明書（絶対にイメージに含めない）
*.pem
*.key
*.crt
*.p12
*.jks

# AWSクレデンシャル
.aws/

# --------------------------------------------
# その他
# --------------------------------------------
# カバレッジレポート
coverage/
.nyc_output/
*.lcov

# パッケージファイル
*.tar
*.tar.gz
*.zip
*.rar

# バックアップファイル
*.bak
*.backup

# ============================================
# 除外の例外
# ============================================
# 特定のファイルは含める必要がある場合
# ! を使って例外を指定できます
#
# 例: target/配下のJARファイルは含めたい場合
# !target/*.jar
